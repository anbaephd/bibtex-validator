	keywords = {Big Data, Cloud computing, Pipelines, Conferences, Benchmark testing, Decision support systems, Apache Spark, cloud-native, kubeflow, TPC-DS, Cluster computing},
	pages = {215--220},
	file = {PDF:/Users/anbae/Zotero/storage/VMTPLAB5/2024 - A Decision Support System for Automated Configuration of Cloud Native ML Pipelines.pdf:application/pdf},
