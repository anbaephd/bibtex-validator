	keywords = {Machine learning, Semantics, Energy efficiency, Ontology, Artificial intelligence systems, Machine learning systems, Machine-learning, Trustworthy artificial intelligence, Ontology-based, Ontology's, Engineering education, Accountability, Semantic approach, Statistical machine learning, Technology-based},
