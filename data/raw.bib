	keywords = {Artificial intelligence, Ontology, Health care, Explainable AI, Semantic Web, AI systems, Systems analysis, System designers, User requirements, End users, Explanation ontology, Modeling of explanations and explanation types, Real-time operation, Supporting explainable ai in clinical decision making and decision support, User-centered, User-centric},
