}

@inproceedings{weerasinghe_ontology_2023,
	address = {Kuliyapitiya, Sri Lanka},
	title = {Ontology {Based} {Machine} {Learning} {Approach} for {Predictive} {Maintenance} of {Industrial} {Robots}},
	copyright = {https://doi.org/10.15223/policy-029},
	isbn = {979-8-3503-1926-2},
	url = {https://ieeexplore.ieee.org/document/10365031/},
	doi = {10.1109/SLAAI-ICAI59257.2023.10365031},
	abstract = {Machine maintenance is crucial in industrial environments for safe and efficient operations. Regular maintenance prevents breakdowns, reduces downtime, and extends machinery lifespan. Currently, reactive and preventive maintenance are commonly practiced. Reactive maintenance repairs machines after failures, leading to unexpected downtime and negative impacts on production. Preventive maintenance follows a predefined schedule to prevent issues, but it can increase costs through inappropriate maintenance and equipment replacements. Predictive maintenance, supported by AI, offers a solution by continuously monitoring machines and predicting faults. This approach minimizes production and maintenance costs, resulting in higher profit margins. This work presents an improved predictive maintenance for industrial machinery based on machine learning and ontology. The objective is to detect patterns in robot health, predict future failures, classify failures, and recommend maintenance tasks. A hybrid maintenance solution is developed, combining ML-based fault prediction with an ontology-based maintenance task recommendation system. The ML model identifies anomalies and patterns for future failure prediction. The ontology model recommends maintenance tasks based on these predictions. The work primarily focuses on the ML-based approach, integrated with the ontology-based approach, to predict machine failures and optimize maintenance strategies, reducing costs and drawbacks of reactive and preventive maintenance.},
	urldate = {2025-06-17},
	booktitle = {2023 7th {SLAAI} {International} {Conference} on {Artificial} {Intelligence} ({SLAAI}-{ICAI})},
