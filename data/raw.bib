@inproceedings{chari_explanation_2020,
	title = {Explanation {Ontology}: {A} {Model} of {Explanations} for {User}-{Centered} {AI}},
	volume = {12507 LNCS},
	isbn = {03029743 (ISSN); 978-303062465-1 (ISBN)},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85096581526&doi=10.1007%2f978-3-030-62466-8_15&partnerID=40&md5=68c1ced6f8129e16ea9cc3040a3b2c32},
	doi = {10.1007/978-3-030-62466-8_15},
	abstract = {Explainability has been a goal for Artificial Intelligence (AI) systems since their conception, with the need for explainability growing as more complex AI models are increasingly used in critical, high-stakes settings such as healthcare. Explanations have often added to an AI system in a non-principled, post-hoc manner. With greater adoption of these systems and emphasis on user-centric explainability, there is a need for a structured representation that treats explainability as a primary consideration, mapping end user needs to specific explanation types and the system’s AI capabilities. We design an explanation ontology to model both the role of explanations, accounting for the system and user attributes in the process, and the range of different literature-derived explanation types. We indicate how the ontology can support user requirements for explanations in the domain of healthcare. We evaluate our ontology with a set of competency questions geared towards a system designer who might use our ontology to decide which explanation types to include, given a combination of users’ needs and a system’s capabilities, both in system design settings and in real-time operations. Through the use of this ontology, system designers will be able to make informed choices on which explanations AI systems can and should provide. © 2020, Springer Nature Switzerland AG.},
	language = {English},
	booktitle = {Lect. {Notes} {Comput}. {Sci}.},
	publisher = {Springer Science and Business Media Deutschland GmbH},
	author = {Chari, S. and Seneviratne, O. and Gruen, D.M. and Foreman, M.A. and Das, A.K. and McGuinness, D.L.},
	editor = {{Pan J.Z.} and {Tamma V.} and {d’Amato C.} and {Janowicz K.} and {Fu B.} and {Polleres A.} and {Seneviratne O.} and {Kagal L.}},
	year = {2020},
